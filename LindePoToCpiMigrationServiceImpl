				coordinateT1.put("x", xOffset);
				coordinateT1.put("y", yOffset);
				coordinateList.add(coordinateT1);
				Map<String, Double> coordinateT2 = new HashMap();
				coordinateT2.put("x", xOffset + AppGenConstant.Branch_Length);// 150
				coordinateT2.put("y", yOffset);
				coordinateList.add(coordinateT2);
				yOffset = yOffset + ((r - 1) * AppGenConstant.Length);
				xOffset = xOffset + AppGenConstant.Branch_Length;
				Map<String, Double> coordinateT3 = new HashMap();
				coordinateT3.put("x", xOffset);
				coordinateT3.put("y", yOffset);
