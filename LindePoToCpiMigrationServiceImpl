		elementShapeList.add(subProcessShape);
//			******************* Creating Subprocess block ******************

//			******************* Creating Start Event Object ******************
		ElementModel startEventObj = new ElementModel();
		addEleAttribute(startEventObj, "ErrStartEvent", "Error Start 1", null,
				appGenUtility.getExtensionElementKeyValue(AppGenConstant.START_EVENT_ERR));
		partiList.add(startEventObj);

		ElementModelShape startEventShape = new ElementModelShape();
		addEleShapeAttri(startEventObj, startEventShape, 32.0, 32.0);
		elementShapeList.add(startEventShape);

		startEventShape.setX(xOffset);
		startEventShape.setY(yOffset);
//			******************************************************************

//			******************* Creating Process Call Object ******************
		ElementModel processCallObj = new ElementModel();
		addEleAttribute(processCallObj, "ErrCallActivity", "RetryConnection_Fail", null,
				appGenUtility.getProcessCall(String.valueOf(1)));
		partiList.add(processCallObj);

		ElementModelShape processCallShape = new ElementModelShape();
		addEleShapeAttri(processCallObj, processCallShape, 80.0, 100.0);
		elementShapeList.add(processCallShape);

//			******Creating a Sequence flow (Arrow) to connect from startEvent to processCall ****
		SequenceFlow sequenceFlowObj = new SequenceFlow();
		addSeqAttribute(sequenceFlowObj, "ErrSequenceFlow_" + 1, startEventObj, processCallObj);
		sequenceFlowList.add(sequenceFlowObj);

		LinkedList<Map<String, Double>> coordinateList = new LinkedList();
		// sequence flow source coordinate
		xOffset = xOffset + startEventShape.getWidth() / 2;
		Map<String, Double> coordinateS = new HashMap();
		coordinateS.put("x", xOffset);
		coordinateS.put("y", yOffset);
		coordinateList.add(coordinateS);
		// sequence flow target coordinate
		xOffset = xOffset + 100.0 + processCallShape.getWidth() / 2;
		Map<String, Double> coordinateT = new HashMap();
		coordinateT.put("x", xOffset);
		coordinateT.put("y", yOffset);
		coordinateList.add(coordinateT);

		SequenceFlowShape seqFlowShape = new SequenceFlowShape();
		addSeqShapeAttri(startEventShape, processCallShape, sequenceFlowObj, coordinateList, seqFlowShape);
		sequenceShapeList.add(seqFlowShape);
//			****************************************************************

		processCallShape.setY(yOffset - processCallShape.getHeight() / 2);
		processCallShape.setX(xOffset - processCallShape.getWidth() / 2);

//			********************* Creating end event object ******************
		ElementModel endEventObj = new ElementModel();
		if (receiverId == null) {
			addEleAttribute(endEventObj, "ErrEndEventMessage_1", "End 1", null,
					appGenUtility.getExtensionElementKeyValue(AppGenConstant.END_EVENT));
		}else
		addEleAttribute(endEventObj, "ErrEndEvent", "End", null,
				appGenUtility.getExtensionElementKeyValue(AppGenConstant.END_EVENT));
		partiList.add(endEventObj);

		ElementModelShape endEventShape = new ElementModelShape();
		addEleShapeAttri(endEventObj, endEventShape, 32.0, 32.0);
		elementShapeList.add(endEventShape);

		SequenceFlow seqEndObj = new SequenceFlow();
		addSeqAttribute(seqEndObj, "ErrSequenceFlow_" + 2, processCallObj, endEventObj);
		sequenceFlowList.add(seqEndObj);

		LinkedList<Map<String, Double>> coordinate_List = new LinkedList();
		// sequence flow source coordinate
		xOffset = xOffset + processCallShape.getWidth() / 2;
		Map<String, Double> coordinate_S = new HashMap();
		coordinate_S.put("x", xOffset);
		coordinate_S.put("y", yOffset);
		coordinate_List.add(coordinate_S);
		// sequence flow target coordinate
		xOffset = xOffset + 100.0 + endEventShape.getWidth() / 2;
		Map<String, Double> coordinate_T = new HashMap();
		if (xOffset > this.bpmnDiagram.getMaxEndEventX())
			this.bpmnDiagram.setMaxEndEventX(xOffset);
		else
			xOffset = this.bpmnDiagram.getMaxEndEventX();
		coordinate_T.put("x", xOffset);
		coordinate_T.put("y", yOffset);
		coordinate_List.add(coordinate_T);
		//
		subProcessShape.setWidth(xOffset - xLaneSet - 90.0);// xOffset - 150.0

		SequenceFlowShape seqEndShape = new SequenceFlowShape();
		addSeqShapeAttri(processCallShape, endEventShape, seqEndObj, coordinate_List, seqEndShape);
		sequenceShapeList.add(seqEndShape);
		//
		endEventShape.setX(xOffset - endEventShape.getWidth() / 2);
		endEventShape.setY(yOffset - endEventShape.getHeight() / 2);
//			******************************************************************

		if (xOffset > this.bpmnDiagram.getParticipantProcessWidth()) {// xOffset+400>this.bpmnDiagram.getParticipantProcessWidth()
			this.bpmnDiagram.setParticipantProcessWidth(xOffset - (AppGenConstant.Length + 100.0));// xOffset+400 //(/2
			// 300)
		}
		if (yOffset > this.bpmnDiagram.getParticipantProcessHeight())
			this.bpmnDiagram.setParticipantProcessHeight(yOffset + 80.0);

		if (receiverId == null) {
			createProcessCallForExceptionProcess1(elementShapeList, sequenceShapeList, msgFlowList, msgShapeList,
					processList, partiList);
		} else
			createProcessCallForExceptionProcess(elementShapeList, sequenceShapeList, msgFlowList, msgShapeList,
					processList, partiList, receiverId);
	}

