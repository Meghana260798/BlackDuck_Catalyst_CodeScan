	private void addMsgFlowAttribute(MessageFlow msgFlow, int messageFlow, String currentNodeId, String previousNodeId,
			ChannelMapModel channelObj, String participantId, Boolean localProcess) {
		if(localProcess) {
		msgFlow.setId("MessageFlow_Local_" + messageFlow);
		}else {
			msgFlow.setId("MessageFlow_" + messageFlow);
		}
		msgFlow.setSourceRef(previousNodeId);
		msgFlow.setTargetRef(currentNodeId);
		String msgFlwName = channelObj.getName();

		 if (channelObj.getName().equalsIgnoreCase("soap")&& channelObj.getDirection().equals("Receiver") &&
					channelObj.getAdapterMetaDataList().get("XMBWS.NoSOAP").equals("1"))
				msgFlwName = "SOAP_HTTP";
		 
		if (channelObj.getMsgProtocol().equalsIgnoreCase("XI") && channelObj.getName().equalsIgnoreCase("soap"))
			msgFlwName = channelObj.getMsgProtocol();

		if (channelObj.getMsgProtocol().equalsIgnoreCase("AxHTTP") && channelObj.getName().equalsIgnoreCase("soap"))
			msgFlwName = "XI";
		if (channelObj.getName().equalsIgnoreCase("file") && channelObj.getTransProtocol().equalsIgnoreCase("FTP"))
			msgFlwName = "FTP";
		if(channelObj.getDirection().equalsIgnoreCase("Sender"))
		{
		if ( null !=channelObj.getTransProtocol() && channelObj.getTransProtocol().equalsIgnoreCase("POP3") && channelObj.getName().equalsIgnoreCase("Mail"))
			msgFlwName = "Mail_POP3";
		if (null !=channelObj.getTransProtocol() && channelObj.getTransProtocol().equalsIgnoreCase("IMAP4") && channelObj.getName().equalsIgnoreCase("Mail"))
			msgFlwName = "Mail_IMAP4";
		}

		msgFlow.setName(msgFlwName);
		msgFlow.setExtensionElementMap(appGenUtility.getExtElementKeyValue(channelObj.getAdapterMetaDataList(),
				msgFlwName, channelObj.getDirection(), participantId));
	}
