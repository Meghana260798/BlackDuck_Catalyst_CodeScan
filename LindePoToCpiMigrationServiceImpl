		RoleData targetData = getRoleData(doc, "TARGET_IFR_MESS");
		if (targetData != null) for (String elem : targetData.getElements())
            try {
                Path schemaPath = path.getParent().getParent().resolve(targetData.typeId + "/" + elem + "." + targetData.typeId);
                if (Files.exists(schemaPath)) Files.delete(schemaPath); // deletes the file
            } catch (Exception e) {
            }

		logger.info("LindePoToCpiMigrationServiceImpl transformLindeMapping() end");
	}

	public void refactorElement(Path path, String sourceRootWithoutNS) {
		try {
			// Namespace handling
			DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
			factory.setNamespaceAware(true);
			DocumentBuilder builder = factory.newDocumentBuilder();
			Document doc = builder.parse(path.toFile());

			final String XSD_NS = "http://www.w3.org/2001/XMLSchema";

			// Find the original xsd:element by name
			NodeList elements = doc.getElementsByTagNameNS(XSD_NS, "element");
			Element originalElement = null;
			for (int i = 0; i < elements.getLength(); i++) {
				Element e = (Element) elements.item(i);
				if (sourceRootWithoutNS.equals(e.getAttribute("name"))) {
					originalElement = e;
					break;
				}
			}
			if (originalElement == null) {
				logger.error("refactorElement(): root element '{}' not found in {}", sourceRootWithoutNS, path);
				return;
			}

			// Step 1: deduce type
			String typeName = originalElement.getAttribute("type");



			// Step 2: create new global element at schema root
			Element schema = (Element) doc.getElementsByTagName("xsd:schema").item(0); // <xsd:schema>
			if (!typeName.isEmpty())
				addXmlToParent(doc, schema, "<xsd:element name=\"ROOT\"><xsd:complexType><xsd:sequence><xsd:element name=\"select_response\" type=\"" + typeName + "\"/></xsd:sequence></xsd:complexType></xsd:element>", 0);
			else
				addXmlToParent(doc, schema, "<xsd:element name=\"ROOT\"><xsd:complexType><xsd:sequence><xsd:element name=\"select_response\"/></xsd:sequence></xsd:complexType></xsd:element>", 0);

			// Step 3: delete original element
			Node parent = originalElement.getParentNode();
			parent.removeChild(originalElement);

			// Write changes back to file (overwrite original path)
			TransformerFactory tf = TransformerFactory.newInstance();
			Transformer transformer = tf.newTransformer();

			transformer.setOutputProperty(OutputKeys.OMIT_XML_DECLARATION, "no");
			transformer.setOutputProperty(OutputKeys.METHOD, "xml");
			transformer.setOutputProperty(OutputKeys.INDENT, "yes");
			transformer.setOutputProperty(OutputKeys.ENCODING, "UTF-8");

			transformer.transform(new DOMSource(doc), new StreamResult(path.toFile()));

			logger.info("refactorElement(): Successfully refactored element '{}' in {}", sourceRootWithoutNS, path);

		} catch (Exception ex) {
			logger.error("refactorElement(): Failed to refactor element '{}' in {}. Error: {}",
					sourceRootWithoutNS, path, ex.getMessage(), ex);
		}
	}

	public static void addXmlToParent(Document doc, Node parent, String xmlSnippet, int index) throws Exception {
		// Parse the snippet into a temporary Document
		DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
		factory.setNamespaceAware(true);
		DocumentBuilder builder = factory.newDocumentBuilder();
		String wrapped = "<root xmlns:xsd=\"http://www.w3.org/2001/XMLSchema\">" + xmlSnippet + "</root>";
		Document tempDoc = builder.parse(new InputSource(new StringReader(wrapped)));

		// Import the root element from the snippet into the main doc
		Node importedNode = doc.importNode(tempDoc.getDocumentElement().getFirstChild(), true);

		// Insert at given index
		NodeList children = parent.getChildNodes();
		if (index < 0 || index > children.getLength()) {
			throw new IndexOutOfBoundsException("Invalid index " + index + ". Child count: " + children.getLength());
		}

		if (index == children.getLength()) {
			// Append at the end
			parent.appendChild(importedNode);
		} else {
			// Insert before the child currently at that index
			Node refNode = children.item(index);
			parent.insertBefore(importedNode, refNode);
		}
	}

