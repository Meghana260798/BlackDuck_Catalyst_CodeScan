	private void prepareDataForReceiverTemplateSync(IcoSenderMapping icoSender, List<ChannelMapModel> channelList,
			List<OperationMapping> operationmappingList, int participant, int messageFlow, int router, int sequenceFlow,
			ElementModel currentElementNode, ElementModel previousElementNode, ElementModel routerElementNode,
			List<ElementModel> partiList, List<MessageFlow> msgFlowList, int excGateway, int callActivity, int endEvent,
			Integer pgpEnc, List<SequenceFlow> sequenceFlowList, List<ElementModelShape> elementShapeList,
			List<MessageFlowShape> msgShapeList, List<SequenceFlowShape> sequenceShapeList, List<Process> processList) throws IOException {
		logger.info("LindePoToCpiMigrationServiceImpl prepareDataForReceiverTemplate() :: Start");
		ElementModelShape currentElementModelShape = this.bpmnDiagram.getCurrentElementModelShape();
		ElementModelShape previousElementModelShape = this.bpmnDiagram.getPreviousElementModelShape();
		ElementModelShape routerElementModelShape = this.bpmnDiagram.getRouterElementModelShape();
		Double yLaneSet = this.bpmnDiagram.getyLaneSet();
		Double xLaneSet = this.bpmnDiagram.getxLaneSet();
		Double xOffset = this.bpmnDiagram.getxOffset();
		Double yOffset = this.bpmnDiagram.getyOffset();
		Double xEndEvent = 0.0;
		Double yEndEvent = 0.0;
		int r = 0;
		int route = 0;// count for routing
		int requestReply = 0;
		List<String> seqList = new LinkedList<String>();
		List<MessageMapping> messageMapList = null;

		getSortedReceiverListForMMCount(operationmappingList, icoSender, channelList);
		ChannelMapModel senderChannelObj = null;
		//senderChannelObj
		if (null != channelList) {
			for (ChannelMapModel channel : channelList) {
				if (icoSender.getSenderChannelId().equalsIgnoreCase(channel.getChannelId())
						&& icoSender.getSenderId().equalsIgnoreCase(channel.getPartyId())
						&& icoSender.getSenderCompId().equalsIgnoreCase(channel.getComponentId())) {
					senderChannelObj = channel;
					if (null != icoSender.getSenProcessDirect() && icoSender.getSenProcessDirect().equals("yes"))
						senderChannelObj.setName("ProcessDirect");

					break;
				}
			}
		}

		if (senderChannelObj.getName().matches("RFC|IDoc_AAE") || senderChannelObj.getMsgProtocol().equalsIgnoreCase("XI")) {
			senderChannelObj = new ChannelMapModel();
			senderChannelObj.setComponentId(icoSender.getSenderCompId());
			senderChannelObj.setName("ProcessDirect");
			senderChannelObj.setMsgProtocol("NA");
			Map<String,String> metadatasender = new HashMap<>();
			metadatasender.put("address",("/DEV/"+icoSender.getSenderCompId()+"/"+icoSender.getInterfaceName()).replaceAll("\\.", "_"));
			senderChannelObj.setAdapterMetaDataList(new HashMap<>());
			senderChannelObj.setDirection("Sender");
		}

		//senderParticipant
		ElementModel senderParticipant = new ElementModel();
		++participant;
		Map<String, String> prop = appGenUtility.getExtensionElementKeyValue(AppGenConstant.SENDER_PAR);
		addEleAttribute(senderParticipant, "Participant_" + participant, senderChannelObj.getComponentId(),
				"EndpointSender", prop);
		partiList.add(senderParticipant);

		yOffset = 100.0;
		xOffset = 40.0;

		ElementModelShape senderParticipantShape = new ElementModelShape();
		senderParticipantShape.setX(xOffset);
		senderParticipantShape.setY(yOffset);
		addEleShapeAttri(senderParticipant, senderParticipantShape, 140.0, 100.0);
		elementShapeList.add(senderParticipantShape);

		previousElementModelShape = senderParticipantShape;

		//start Event
		ElementModel startEventObj = new ElementModel();
		addEleAttribute(startEventObj, "StartEvent_" + 1, "Start", null,
				appGenUtility.getExtensionElementKeyValue(AppGenConstant.START_EVENT));
		partiList.add(startEventObj);
		currentElementNode = startEventObj;

		ElementModelShape startEventShape = new ElementModelShape();
		addEleShapeAttri(startEventObj, startEventShape, 32.0, 32.0);
		elementShapeList.add(startEventShape);

		currentElementModelShape = startEventShape;

		yLaneSet = yOffset + previousElementModelShape.getHeight() / 2;
		xLaneSet = xOffset + previousElementModelShape.getWidth() / 2;
		yOffset = yLaneSet;
		xOffset = xLaneSet;
		// check if adapter exist
		Boolean adapter = AppGenConstant.ADAPTERS.contains(senderChannelObj.getName());
		if (adapter) {
			MessageFlow msgFlowObj = new MessageFlow();
			++messageFlow;

			addMsgFlowAttribute(msgFlowObj, messageFlow, startEventObj.getId(), senderParticipant.getId(),
					senderChannelObj, senderParticipant.getId(),false);
			msgFlowList.add(msgFlowObj);

			LinkedList<Map<String, Double>> coordinateList = new LinkedList();
			// source
			Map<String, Double> coordinate = new HashMap();
			coordinate.put("x", xOffset);
			coordinate.put("y", yOffset);
			coordinateList.add(coordinate);
			// target
			double sp = xOffset + AppGenConstant.Length + startEventShape.getWidth() / 2;
			xOffset = xOffset + AppGenConstant.Length + startEventShape.getWidth() / 2;
			Map<String, Double> coordinateS = new HashMap();
			coordinateS.put("x", xOffset);
			coordinateS.put("y", yOffset);
			coordinateList.add(coordinateS);

			MessageFlowShape msgFlowShape = new MessageFlowShape();
			addMsgShapeAttri(senderParticipantShape, startEventShape, msgFlowObj, coordinateList, msgFlowShape);
			msgShapeList.add(msgFlowShape);
		} else {
			// just add length
			xOffset = xOffset + AppGenConstant.Length + startEventShape.getWidth() / 2;
		}
		xOffset = xOffset - startEventShape.getWidth() / 2;

		currentElementModelShape.setX(xOffset);
		currentElementModelShape.setY(yOffset - currentElementModelShape.getHeight() / 2);


		for (IcoReceiverInterface receiver : icoSender.getIcoRecevList()) {
			Double xSync = 0.0;
			Double ySync = 0.0;
			boolean sync = false;
			ElementModel syncObj = new ElementModel();
			ElementModelShape syncShape = new ElementModelShape();

			List<MappingParameter> mappingParameter= new ArrayList<>();
			List<MappingParameter> headerParameter= new ArrayList<>();

			ElementModel contentModifier = new ElementModel();
			callActivity++;
		        mappingParameter.add(new MappingParameter("constant", "SAP_Receiver", receiver.getReceiverCompId()));
		        mappingParameter.add(new MappingParameter("constant", "SAP_Sender", icoSender.getSenderCompId()));
		        mappingParameter.add(new MappingParameter("constant", "ReceiverInterface", receiver.getReceiverInterface()));
		        mappingParameter.add(new MappingParameter("constant", "ReceiverNamespace", receiver.getReceiverNamespace()));
		        mappingParameter.add(new MappingParameter("constant", "CUSTOM_HEADERS", "ReceiverInterface"));

		        headerParameter.add(new MappingParameter("constant", "logPayload", "false"));

		        appGenUtility.addCFProperties(mappingParameter, "CallActivity_" + callActivity);
		        appGenUtility.addCFProperties(headerParameter, "CallActivity_" + callActivity);

			addEleAttribute(contentModifier, "CallActivity_" + callActivity,
					"Update Header Properties", null,
					appGenUtility.getContentModifier(mappingParameter, headerParameter,""));
			partiList.add(contentModifier);
			previousElementNode = currentElementNode;
			currentElementNode = contentModifier;

			ElementModelShape contentModifierShape = new ElementModelShape();
			addEleShapeAttri(contentModifier, contentModifierShape, 70.0, 90.0);
			elementShapeList.add(contentModifierShape);
			previousElementModelShape = currentElementModelShape;
			currentElementModelShape = contentModifierShape;

			SequenceFlow seqCallActObj = new SequenceFlow();
			sequenceFlow++;
			route = addSeqAttributes(icoSender, sequenceFlow, currentElementNode, previousElementNode, r,
					route, seqList, receiver, seqCallActObj,false);
			sequenceFlowList.add(seqCallActObj);

			addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet,
					currentElementModelShape, previousElementModelShape, seqCallActObj, xOffset, yOffset);
			xOffset = this.x;
			yOffset = this.y;


			//groovy
			ElementModel callActivityObj = new ElementModel();
			callActivity++;
			addEleAttribute(callActivityObj,"CallActivity_" + callActivity,"log Sender Payload",null,appGenUtility.getGroovy("LogPayload","LogPayload"));

			partiList.add(callActivityObj);
			previousElementNode = currentElementNode;
			currentElementNode = callActivityObj;

			ElementModelShape callActivityShape = new ElementModelShape();
			addEleShapeAttri(callActivityObj, callActivityShape, 80.0, 100.0);
			elementShapeList.add(callActivityShape);
			previousElementModelShape = currentElementModelShape;
			currentElementModelShape = callActivityShape;

			//
			seqCallActObj = new SequenceFlow();
			sequenceFlow++;
			route = addSeqAttributes(icoSender, sequenceFlow, currentElementNode, previousElementNode, r,
					route, seqList, receiver, seqCallActObj,false);
			sequenceFlowList.add(seqCallActObj);

			addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet,
					currentElementModelShape, previousElementModelShape, seqCallActObj, xOffset, yOffset);
			xOffset = this.x;
			yOffset = this.y;

				if(operationmappingList!=null && !operationmappingList.isEmpty()) {

					List<MessageMapping> messageMappingList = null;
					for (OperationMapping operationMap : operationmappingList) {// match swid too
						if (null != receiver.getOpMappingName()
								&& receiver.getOpMappingName().equalsIgnoreCase(operationMap.getOperationMappingName())
								&& receiver.getOpMappingNamespace().equalsIgnoreCase(operationMap.getOperationMappingNmspc())) {
							messageMappingList = operationMap.getMappingList().stream()
								    .map(Mapping::getMessageMapping)
								    .filter(msg -> msg != null)
								    .collect(Collectors.toList());
							break;
						}
					}
					int c=1;
					for (MessageMapping messageMap : messageMappingList) {
					if (messageMap.isSync()) {

						ElementModel requestReplyObj = new ElementModel();
						requestReply++;
						addEleAttribute(requestReplyObj, "ServiceTask_" + requestReply, "Request Reply " + requestReply,
								null, appGenUtility.getExtensionElementKeyValue(AppGenConstant.REQUESTREPLY));
						partiList.add(requestReplyObj);
						previousElementNode = currentElementNode;
						currentElementNode = requestReplyObj;

						ElementModelShape requestReplyShape = new ElementModelShape();
						addEleShapeAttri(requestReplyObj, requestReplyShape, 80.0, 100.0);
						elementShapeList.add(requestReplyShape);
						previousElementModelShape = currentElementModelShape;
						currentElementModelShape = requestReplyShape;

						SequenceFlow seqRequestReplyObj = new SequenceFlow();
						sequenceFlow++;
						route = addSeqAttributes(icoSender, sequenceFlow, currentElementNode, previousElementNode, r,
								route, seqList, receiver, seqRequestReplyObj,false);
						sequenceFlowList.add(seqRequestReplyObj);

						addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet,
								currentElementModelShape, previousElementModelShape, seqRequestReplyObj, xOffset,
								yOffset);
						xOffset = this.x;
						yOffset = this.y;

						xSync = this.x + previousElementModelShape.getWidth() / 2;
						ySync = this.y;
						sync = true;
						syncObj = requestReplyObj;
						syncShape = requestReplyShape;
					}
					String mmName="MM Request";
					String localIntName="Request Mapping";
					if (messageMap.isSync()) {
						mmName="MM Response";
						localIntName="Response Mapping";
					}

				ElementModel processCall = new ElementModel();
				callActivity++;
				addEleAttribute(processCall, "CallActivity_" + callActivity, mmName, null,
						appGenUtility.getProcessCall(Integer.toString(c)));
				partiList.add(processCall);


				int localIntegrationId=c;
				List<Mapping> mappingList1 = new ArrayList<>();
				Mapping mp= new Mapping();
				mp.setMessageMapping(messageMap);
				mappingList1.add(mp);
				operationmappingList.get(0).setMappingList(mappingList1);

				createLocalIntegrationforMM(icoSender,receiver,channelList,operationmappingList,elementShapeList, sequenceShapeList,
						msgFlowList, msgShapeList,processList,partiList,localIntegrationId,1000*(c-1),900,false,localIntName);
				c++;

				previousElementNode = currentElementNode;
				currentElementNode = processCall;

				ElementModelShape processCallShape = new ElementModelShape();
				addEleShapeAttri(processCall, processCallShape, 80.0, 100.0);
				elementShapeList.add(processCallShape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = processCallShape;

				SequenceFlow sequenceFlowObj = new SequenceFlow();
				sequenceFlow++;
				addSeqAttribute(sequenceFlowObj, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
				sequenceFlowList.add(sequenceFlowObj);

				LinkedList<Map<String, Double>> coordinate_List = new LinkedList();
						// source
						xOffset = xOffset + previousElementModelShape.getWidth() / 2;
						Map<String, Double> coordinate_S = new HashMap();
						coordinate_S.put("x", xOffset);
						coordinate_S.put("y", yOffset);
						coordinate_List.add(coordinate_S);
						// target
						xOffset = xOffset + AppGenConstant.Length + currentElementModelShape.getWidth() / 2;
						Map<String, Double> coordinateT = new HashMap();
						coordinateT.put("x", xOffset);
						coordinateT.put("y", yOffset);
						coordinate_List.add(coordinateT);

						SequenceFlowShape seqFlowShape = new SequenceFlowShape();
						addSeqShapeAttri(previousElementModelShape, currentElementModelShape, sequenceFlowObj, coordinate_List,
								seqFlowShape);
						sequenceShapeList.add(seqFlowShape);

						currentElementModelShape.setY(yOffset - currentElementModelShape.getHeight() / 2);
						currentElementModelShape.setX(xOffset - currentElementModelShape.getWidth() / 2);
		}

				}
			// get channel info here
			ChannelMapModel receiverChannelObj = null;

			if (null != channelList) {
				for (ChannelMapModel channel : channelList) {
					if (receiver.getReceiverChannelId().equalsIgnoreCase(channel.getChannelId())
							&& receiver.getReceiverId().equalsIgnoreCase(channel.getPartyId())
							&& receiver.getReceiverCompId().equalsIgnoreCase(channel.getComponentId())) {
						receiverChannelObj = channel;

						if (null != receiverChannelObj.getSoapToHttp()
								&& receiverChannelObj.getSoapToHttp().equals("Yes"))
							receiverChannelObj.setName("HTTP_AAE");
						break;
					}
				}
			}

			// pgp encryptor

			for(  Map.Entry<String, String> module:receiverChannelObj.getMod().entrySet()) {

			String scriptName= module.getKey().split("\\|")[0];
			String pkey=	module.getValue();
			if(!scriptName.matches("PGPDecryption|PGPEncryption|PayloadZipBean")) {
			Map<String,String> parameters=	receiverChannelObj.getModParamters().get(pkey);
		 mappingParameter= new ArrayList<>();
				for (Map.Entry<String,String> entry : parameters.entrySet()) {
					MappingParameter mp = new MappingParameter();
					mp.setName(entry.getKey());
					mp.setValue(entry.getValue());
					mp.setType("");
					mappingParameter.add(mp);
				}

				 contentModifier = new ElementModel();
				callActivity++;
				addEleAttribute(contentModifier, "CallActivity_" + callActivity,"Content Modifier"+callActivity, null,
						appGenUtility.getContentModifier(mappingParameter, false,""));
				partiList.add(contentModifier);
				previousElementNode = currentElementNode;
				currentElementNode = contentModifier;

				 contentModifierShape = new ElementModelShape();
				addEleShapeAttri(contentModifier, contentModifierShape, 70.0, 90.0);
				elementShapeList.add(contentModifierShape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = contentModifierShape;

				 seqCallActObj = new SequenceFlow();
				sequenceFlow++;
				addSeqAttribute(seqCallActObj, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
				sequenceFlowList.add(seqCallActObj);

				addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, 0.0, 0.0,
						currentElementModelShape, previousElementModelShape, seqCallActObj, xOffset, yOffset);
				xOffset = this.x;
				yOffset = this.y;
			}
				//groovy
				 callActivityObj = new ElementModel();
				callActivity++;
				if(!scriptName.matches("PGPDecryption|PGPEncryption|PayloadZipBean")) {
					addEleAttribute(callActivityObj,"CallActivity_" + callActivity,scriptName,null,appGenUtility.getGroovy(AppGenConstant.getScriptName().get(scriptName),"BeanScriptGroovyCollection"));
					}else if(scriptName.equals("PayloadZipBean")) {
						Map<String,String> parameters=	receiverChannelObj.getModParamters().get(pkey);
						String type=parameters.get("zip.mode");
						if("unzip".equals(type)) {
							Map<String, String> prope = appGenUtility.getExtensionElementKeyValue(AppGenConstant.ZIP_SPLITTER);
							addEleAttribute(callActivityObj, "CallActivity_" + callActivity,"Zip Splitter",null, prope);
						}else if("zipAll".equals(type)) {
							Map<String, String> prope = appGenUtility.getExtensionElementKeyValue(AppGenConstant.ZIP_GATHER);
							addEleAttribute(callActivityObj, "CallActivity_" + callActivity,
									"Gather",null, prope);
						}else if("zip".equals(type)) {
							Map<String, String> prope = appGenUtility.getExtensionElementKeyValue(AppGenConstant.ZIP_ENC);
							addEleAttribute(callActivityObj, "CallActivity_" + callActivity,
									"ZIP Compression",null, prope);
						}
					}else if(scriptName.equals("PGPEncryption")) {
						Map<String, String> pgpProp =appGenUtility.getPGPEncp(receiverChannelObj.getModParamters().get(pkey));

						addEleAttribute(callActivityObj, "CallActivity_" + callActivity, "PGPEncryptor", null, pgpProp);
					}else if(scriptName.equals("PGPDecryption")) {
						Map<String, String> pgpProp = appGenUtility.getPGPDecrypt(receiverChannelObj.getModParamters().get(pkey));

						addEleAttribute(callActivityObj, "CallActivity_" + callActivity, "PGPDecryptor", null, pgpProp);
					}

				partiList.add(callActivityObj);
				previousElementNode = currentElementNode;
				currentElementNode = callActivityObj;

				 callActivityShape = new ElementModelShape();
				addEleShapeAttri(callActivityObj, callActivityShape, 80.0, 100.0);
				elementShapeList.add(callActivityShape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = callActivityShape;

				 seqCallActObj = new SequenceFlow();
				sequenceFlow++;
				addSeqAttribute(seqCallActObj, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
				sequenceFlowList.add(seqCallActObj);
				// this for help branching

				addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, 0.0, 0.0,
						currentElementModelShape, previousElementModelShape, seqCallActObj, xOffset, yOffset);
				xOffset = this.x;
				yOffset = this.y;
			}

			if (receiverChannelObj.getName().equals("REST")) {
