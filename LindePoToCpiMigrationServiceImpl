	private void getSortedReceiverListForMMCount(List<OperationMapping> operationmappingList,
			IcoSenderMapping icoSender, List<ChannelMapModel> channelList) {
		if (operationmappingList != null) {
			for (OperationMapping operationMap : operationmappingList) {
				for (IcoReceiverInterface receiver : icoSender.getIcoRecevList()) {
					if (null != receiver.getOpMappingName()
							&& receiver.getOpMappingName().equalsIgnoreCase(operationMap.getOperationMappingName())
							&& receiver.getOpMappingNamespace()
									.equalsIgnoreCase(operationMap.getOperationMappingNmspc())) {
						int mmCount = operationMap.getMappingList().size();// set

                        mmCount += operationMap.getMappingList().stream()
                        	    .map(Mapping::getMessageMapping)
                        	    .filter(msg -> msg != null)
                        	    .collect(Collectors.toList()).stream()
                                .filter(mm -> !Objects.isNull(mm.getParameterisedValues())).count();

						receiver.setCountMM(mmCount);
					}
				}

			}
		}
		// count exclusive router and pgp element for receiver
		for (IcoReceiverInterface receiver : icoSender.getIcoRecevList()) {
			if (receiver.getCondition() != null && !receiver.getCondition().isEmpty()) {
				receiver.setCountMM(receiver.getCountMM() + 1);
			}
			if (null != channelList) {
				for (ChannelMapModel channelR : channelList) {
					if (receiver.getIcoRecId().equals(channelR.getIcoRecId())) {
						if (channelR.getPgpElement() != null && !channelR.getPgpElement().isEmpty())
							receiver.setCountMM(receiver.getCountMM() + 1);
					}
				}
			}
		}
		Collections.sort(icoSender.getIcoRecevList());
	}

