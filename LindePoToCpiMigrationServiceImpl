	public void transformLindeMapping(Path path, boolean isSenderJDBC) throws Exception {
		logger.info("LindePoToCpiMigrationServiceImpl transformLindeMapping() start");
		DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
		factory.setNamespaceAware(true);
		DocumentBuilder builder = factory.newDocumentBuilder();
		Document doc = builder.parse(path.toFile());
		String targetRoot, sourceRoot = "";

		//transformations
		{
			// get all <brick> elements
			NodeList brickNodes = doc.getElementsByTagName("brick");
			List<Element> bricks = new ArrayList<>();

			for (int i = 0; i < brickNodes.getLength(); i++) {
				Node n = brickNodes.item(i);
				if (n.getNodeType() == Node.ELEMENT_NODE) bricks.add((Element) n);
			}

			String[] parts = ((Element) brickNodes.item(0)).getAttribute("path").split("/", 3);
			targetRoot = (parts.length > 1 ? parts[1] : "").trim();

			NodeList transformations = doc.getElementsByTagName("transformation");
