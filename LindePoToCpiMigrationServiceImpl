	private void addEleAttribute(ElementModel element, String id, String name, String type, Map<String, String> prop)
			throws IOException {
		element.setId(id);
		element.setName(name);
		element.setType(type);
		element.setExtensionElementMap(prop);
	}
	private void addEleShapeAttri(ElementModel elementObj, ElementModelShape elementShape, Double height,
			Double width) {
		elementShape.setShapeId("BPMNShape_" + elementObj.getId());
		elementShape.setBpmnElement(elementObj.getId());
		elementShape.setHeight(height);
		elementShape.setWidth(width);
	}
	// add sequence flow shape attributes
		private void addSeqShapeAttri(ElementModelShape prevShape, ElementModelShape currentShape,
				SequenceFlow sequenceFlowObj, LinkedList<Map<String, Double>> coordinateList,
				SequenceFlowShape seqFlowShape) {
			seqFlowShape.setShapeId("BPMNEdge_" + sequenceFlowObj.getId());
			seqFlowShape.setBpmnElement(sequenceFlowObj.getId());
			seqFlowShape.setSourceElement(prevShape.getShapeId());
			seqFlowShape.setTargetElement(currentShape.getShapeId());
			seqFlowShape.setWaypoint(coordinateList);
		}

		// add sequential attribute
		private void addSeqAttribute(SequenceFlow sequenceFlowObj, String id, ElementModel previousElement,
				ElementModel currentElement) {
			sequenceFlowObj.setId(id);
			sequenceFlowObj.setSourceRef(previousElement.getId());
			sequenceFlowObj.setTargetRef(currentElement.getId());
			currentElement.setIncoming(setIncomingList(sequenceFlowObj, currentElement));
			previousElement.setOutgoing(setOutgoingList(sequenceFlowObj, previousElement));
		}


		// add message flow shape attributes
		private void addMsgShapeAttri(ElementModelShape senderParticipantShape, ElementModelShape startEventShape,
				MessageFlow msgFlowObj, LinkedList<Map<String, Double>> coordinateList, MessageFlowShape msgFlowShape) {
			msgFlowShape.setShapeId("BPMNEdge_" + msgFlowObj.getId());
			msgFlowShape.setBpmnElement(msgFlowObj.getId());
			msgFlowShape.setSourceElement(senderParticipantShape.getShapeId());
			msgFlowShape.setTargetElement(startEventShape.getShapeId());
			msgFlowShape.setWaypoint(coordinateList);
		}

