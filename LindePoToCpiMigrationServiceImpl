		private int addSeqAttributes(IcoSenderMapping icoSender, int sequenceFlow, ElementModel currentElementNode,
				ElementModel previousElementNode, int r, int route, List<String> seqList, IcoReceiverInterface receiver,
				SequenceFlow seqEndEventObj, Boolean localProcess) throws IOException {
			// sequence flow attribute
			if(localProcess) {
				addSeqAttribute(seqEndEventObj, "SequenceFlowL_" + sequenceFlow, previousElementNode, currentElementNode);
			}else {
			addSeqAttribute(seqEndEventObj, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
			}
			// check for previous element node
			if (previousElementNode.getId().contains("Router")) {
				seqEndEventObj.setName("Branch " + r);
				seqList.add(seqEndEventObj.getId());
				if (r == icoSender.getIcoRecevList().size()) {
					Map<String, String> routerPropMap = appGenUtility.getPropertyRouter(seqList);
					previousElementNode.setExtensionElementMap(routerPropMap);
				}
			}else if(previousElementNode.getId().contains("ParallelGateway")) {
				seqEndEventObj.setName("Branch " + r);
			} else if (previousElementNode.getId().contains("ExclusiveGateway")) {
				route++;
				seqEndEventObj.setName("Route" + route);
				if(null != receiver) {
				seqEndEventObj.setConditionExp(receiver.getInterfaceCondition());
				}
				seqEndEventObj
						.setExtensionElementMap(appGenUtility.getExtensionElementKeyValue(AppGenConstant.SEQUENCE_FLOW));
			}
			return route;
		}
