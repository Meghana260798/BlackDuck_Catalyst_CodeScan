		private void addBranching(int r, ElementModel previousElementNode, ElementModel currentElementNode,
				List<SequenceFlowShape> sequenceShapeList, Double xLaneSet, Double yLaneSet,
				ElementModelShape currentElementModelShape, ElementModelShape previousElementModelShape,
				SequenceFlow seqCallActObj, Double xOffset, Double yOffset) {
			LinkedList<Map<String, Double>> coordinateList = new LinkedList();
			if (r > 1 && (previousElementNode.getId().contains("Router") ||previousElementNode.getId().contains("ParallelGateway") ||previousElementNode.getId().contains("ExclusiveGateway"))) {
				xOffset = xLaneSet;
