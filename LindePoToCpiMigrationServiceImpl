							addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet, currentElementModelShape, previousElementModelShape, arrow, xOffset, yOffset);
							xOffset = this.x;
							yOffset = this.y;
						}

					}

					// xslt Mapping
					if (map.getXsltMapping() != null) {
						XsltMapping xsltMap = map.getXsltMapping();
						elementModel = new ElementModel();
						callActivity++;
						String GSName="";
	            		if(xsltMap.getName().contains("/")) {
	            			String[] parts = xsltMap.getName().split("/");
	            		GSName = parts[parts.length - 1];
	            		}else
	            			GSName=xsltMap.getName();
	                    
						addEleAttribute(elementModel, "CallActivity_" + callActivity, xsltMap.getXsltName(), null,
								appGenUtility.getPropDefCallActivityXslt(GSName, xsltMap.getType()));
						partiList.add(elementModel);
						previousElementNode = currentElementNode;
						currentElementNode = elementModel;

						logger.info("Previuos element node Mapping:" + previousElementNode.getName() + " Current Element Node Mapping:" + currentElementNode.getName());

						shape = new ElementModelShape();
						addEleShapeAttri(elementModel, shape, 80.0, 100.0);
						elementShapeList.add(shape);
						previousElementModelShape = currentElementModelShape;
						currentElementModelShape = shape;

						arrow = new SequenceFlow();
						sequenceFlow++;
						route = addSeqAttributes(icoSender, sequenceFlow, currentElementNode, previousElementNode, r, route,
								seqList, receiver, arrow, false);
						sequenceFlowList.add(arrow);
						// this for help branching
						addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet,
								currentElementModelShape, previousElementModelShape, arrow, xOffset, yOffset);
						xOffset = this.x;
						yOffset = this.y;
					}

					// java mapping
					if (map.getJavaMapping() != null) {
						JavaMapping java = map.getJavaMapping();
						for (String name : java.getFilenames()) {
							if (null != java.getGSName() && name.contains(java.getGSName())) {
							elementModel = new ElementModel();
							callActivity++;
							addEleAttribute(elementModel, "CallActivity_" + callActivity, name, null,
									appGenUtility.getGroovy(name, ""));
							partiList.add(elementModel);
							previousElementNode = currentElementNode;
							currentElementNode = elementModel;

							logger.info("Previuos element node Mapping :" + previousElementNode.getName() + " Current Element Node Mapping:" + currentElementNode.getName());

							shape = new ElementModelShape();
							addEleShapeAttri(elementModel, shape, 80.0, 100.0);
							elementShapeList.add(shape);
							previousElementModelShape = currentElementModelShape;
							currentElementModelShape = shape;

							arrow = new SequenceFlow();
							sequenceFlow++;
							route = addSeqAttributes(icoSender, sequenceFlow, currentElementNode, previousElementNode, r, route,
									seqList, receiver, arrow, false);
							sequenceFlowList.add(arrow);
							// this for help branching
							addBranching(r, previousElementNode, currentElementNode, sequenceShapeList, xLaneSet, yLaneSet,
									currentElementModelShape, previousElementModelShape, arrow, xOffset, yOffset);
							xOffset = this.x;
							yOffset = this.y;
							}
						}
					}
				}

			}
			// LogPayloadAfterMapping Groovy
			{
				elementModel = new ElementModel();
				callActivity++;
				addEleAttribute(elementModel, "CallActivity_" + callActivity, "LogPayloadAfterMapping", null, appGenUtility.getGroovy("LogPayload", "LogPayload"));

				partiList.add(elementModel);
				previousElementNode = currentElementNode;
				currentElementNode = elementModel;

				shape = new ElementModelShape();
				addEleShapeAttri(elementModel, shape, 80.0, 100.0);
				elementShapeList.add(shape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = shape;

				arrow = new SequenceFlow();
				sequenceFlow++;
				addSeqAttribute(arrow, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
				sequenceFlowList.add(arrow);
				// this for help branching

				addBranching(1, previousElementNode, currentElementNode, sequenceShapeList, 0.0, 0.0,
						currentElementModelShape, previousElementModelShape, arrow, xOffset, yOffset);
				xOffset = this.x;
				yOffset = this.y;
			}
			// End Event
			{
				elementModel = new ElementModel();
				callActivity++;
				addEleAttribute(elementModel, "EndEvent_" + endEvent, "End", null, appGenUtility.getExtensionElementKeyValue(AppGenConstant.END_EVENT));

				partiList.add(elementModel);
				previousElementNode = currentElementNode;
				currentElementNode = elementModel;

				shape = new ElementModelShape();
				addEleShapeAttri(elementModel, shape, 32.0, 32.0);
				elementShapeList.add(shape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = shape;

				arrow = new SequenceFlow();
				sequenceFlow++;
				addSeqAttribute(arrow, "SequenceFlow_" + sequenceFlow, previousElementNode, currentElementNode);
				sequenceFlowList.add(arrow);
				// this for help branching

				addBranching(1, previousElementNode, currentElementNode, sequenceShapeList, 0.0, 0.0,
						currentElementModelShape, previousElementModelShape, arrow, xOffset, yOffset);
				xOffset = this.x;
				yOffset = this.y;
			}
			// Participant Receiver
			{
				elementModel = new ElementModel();
				participant++;
				addEleAttribute(elementModel, "Participant_" + participant, "Receiver", "EndpointRecevier", appGenUtility.getExtensionElementKeyValue(AppGenConstant.RECEIVER_PAR));

				partiList.add(elementModel);
				previousElementNode = currentElementNode;
				currentElementNode = elementModel;

				shape = new ElementModelShape();
				addEleShapeAttri(elementModel, shape, 140.0, 100.0);
				elementShapeList.add(shape);
				previousElementModelShape = currentElementModelShape;
				currentElementModelShape = shape;

				MessageFlow sendMsgFlow = new MessageFlow();
				messageFlow++;
				Map<String, String> attributes = new HashMap<>();
				ChannelMapModel receiverChannelObj = new ChannelMapModel();
				{
					attributes.put("ChannelID", "JMS");
					attributes.put("QueueName_outbound", "Linde_NonSAP_SFDC_Receiver_AsynchMessage");
					receiverChannelObj.setName("JMS");
					receiverChannelObj.setAdapterMetaDataList(attributes);
					receiverChannelObj.setMsgProtocol("NA");
					receiverChannelObj.setTransProtocol("NA");
					receiverChannelObj.setDirection("Receiver");
				}

				addMsgFlowAttribute(sendMsgFlow, messageFlow, currentElementNode.getId(), previousElementNode.getId(), receiverChannelObj, currentElementNode.getId(), false);
				msgFlowList.add(sendMsgFlow);

				coordinateList = new LinkedList<>();

				Map<String, Double> coordinates = new HashMap<>();
				coordinates.put("x", xOffset);
				coordinates.put("y", yOffset);
				coordinateList.add(coordinates);

				coordinates = new HashMap<>();
				coordinates.put("x", xOffset);
				coordinates.put("y", yOffset - 300.0);
				coordinateList.add(coordinates);

				MessageFlowShape sendMsgFlowShape = new MessageFlowShape();
				addMsgShapeAttri(previousElementModelShape, currentElementModelShape, sendMsgFlow, coordinateList,
						sendMsgFlowShape);
				msgShapeList.add(sendMsgFlowShape);
				currentElementModelShape.setY(yOffset - 300.0);
				currentElementModelShape.setX(xOffset);

			}


		}
		if (xOffset > this.bpmnDiagram.getMaxEndEventX())
			this.bpmnDiagram.setMaxEndEventX(xOffset);
		else
			xOffset = this.bpmnDiagram.getMaxEndEventX();

		createExceptionSubProcessForLinde2(partiList, elementShapeList, sequenceFlowList, sequenceShapeList, msgFlowList,
				msgShapeList, xLaneSet, yLaneSet, 2, icoSender.getErrorHandlingTemplet(), participant, messageFlow);
		if (xOffset > this.bpmnDiagram.getParticipantProcessWidth()) {// xOffset+400>this.bpmnDiagram.getParticipantProcessWidth()
			this.bpmnDiagram.setParticipantProcessWidth(xOffset);// xOffset+400 //(/2
			// 300)
		}
		if (yOffset > this.bpmnDiagram.getParticipantProcessHeight())
			this.bpmnDiagram.setParticipantProcessHeight(yOffset + 80.0);// yOffset+400/+-80.0
		logger.info("LindePoToCpiMigrationServiceImpl prepareDataForReceiverTemplate1ToN() :: End");
	}

	private void createExceptionSubProcessForLinde2(List<ElementModel> partiList, List<ElementModelShape> elementShapeList,
													List<SequenceFlow> sequenceFlowList, List<SequenceFlowShape> sequenceShapeList,
													List<MessageFlow> msgFlowList, List<MessageFlowShape> msgShapeList, Double xLaneSet, Double yLaneSet, int r,
													String errorHandlingTemplet, int participant, int messageFlow) throws IOException {
		Double xOffset = xLaneSet + 230.0;// ;//220.0; //290
		Double yOffset = yLaneSet + r * AppGenConstant.Length;
		int requestReply = 0;
		int callActivity = 0;

		// subprocess element
		ElementModel subProcess = new ElementModel();
		Map<String, String> prop = appGenUtility.getExtensionElementKeyValue(AppGenConstant.SUBPROCESS);
		addEleAttribute(subProcess, "SubProcess_1", "Exception Subprocess", null, prop);
		partiList.add(subProcess);

		// subprocess shape
		ElementModelShape subProcessShape = new ElementModelShape();
		subProcessShape.setX(xOffset - 30.0);// 190.0
		subProcessShape.setY(yOffset - 100);
		addEleShapeAttri(subProcess, subProcessShape, 200.0, 600.0);
		elementShapeList.add(subProcessShape);

		// errorstart element
		ElementModel startEventObj = new ElementModel();
		addEleAttribute(startEventObj, "ErrStartEvent", "Error Start 1", null,
				appGenUtility.getExtensionElementKeyValue(AppGenConstant.START_EVENT_ERR));
		partiList.add(startEventObj);

		// errorstart shape
		ElementModelShape startEventShape = new ElementModelShape();
		addEleShapeAttri(startEventObj, startEventShape, 32.0, 32.0);
		elementShapeList.add(startEventShape);
		startEventShape.setX(xOffset);
		startEventShape.setY(yOffset);

		// groovy element
		ElementModel callActivityObj = new ElementModel();
		addEleAttribute(callActivityObj, "ErrCallActivity", "SetExceptionLogWithPayload", null,
				appGenUtility.getGroovy("SetExceptionLogWithPayload", "SetExceptionMessageLog"));
		partiList.add(callActivityObj);

		// groovy shape
		ElementModelShape callActivityShape = new ElementModelShape();
		addEleShapeAttri(callActivityObj, callActivityShape, 80.0, 100.0);
		elementShapeList.add(callActivityShape);

		// start to groovy flow
		SequenceFlow sequenceFlowObj = new SequenceFlow();
		addSeqAttribute(sequenceFlowObj, "ErrSequenceFlow_" + 1, startEventObj, callActivityObj);
		sequenceFlowList.add(sequenceFlowObj);

		LinkedList<Map<String, Double>> coordinateList = new LinkedList();
		// sequence flow source start error coordinate
		xOffset = xOffset + startEventShape.getWidth() / 2;
		Map<String, Double> coordinateS = new HashMap();
		coordinateS.put("x", xOffset);
		coordinateS.put("y", yOffset);
		coordinateList.add(coordinateS);
		// sequence flow target groovy coordinate
		xOffset = xOffset + 100.0 + callActivityShape.getWidth() / 2;
		Map<String, Double> coordinateT = new HashMap();
		coordinateT.put("x", xOffset);
		coordinateT.put("y", yOffset);
		coordinateList.add(coordinateT);

		SequenceFlowShape seqFlowShape = new SequenceFlowShape();
		addSeqShapeAttri(startEventShape, callActivityShape, sequenceFlowObj, coordinateList, seqFlowShape);
		sequenceShapeList.add(seqFlowShape);

		callActivityShape.setY(yOffset - callActivityShape.getHeight() / 2);
		callActivityShape.setX(xOffset - callActivityShape.getWidth() / 2);

		ElementModel currentElementNode = callActivityObj, previousElementNode = null;
		ElementModelShape currentElementModelShape = callActivityShape, previousElementModelShape = null;
		// err request reply

		// call processing flow request reply

		ElementModel contenModifier = new ElementModel();
		callActivity++;
//		addEleAttribute(contenModifier, "ErrServiceTask_" + requestReply, "Call Generic Exception Handler", null, appGenUtility.getExtensionElementKeyValue());
		List<MappingParameter> headers = new ArrayList<>();
		List<MappingParameter> properties = new ArrayList<>();
		properties.add(new MappingParameter("constant", "SAP_MessageProcessingLogCustomStatus", "MappingFailed" ));
		addEleAttribute(contenModifier, "ErrCallActivity_" + callActivity, "SetCustomFailedStatus", null, appGenUtility.getContentModifier(headers, properties, ""));

		partiList.add(contenModifier);
		previousElementNode = currentElementNode;
		currentElementNode = contenModifier;

		ElementModelShape requestReplyShape = new ElementModelShape();
		addEleShapeAttri(contenModifier, requestReplyShape, 80.0, 100.0);
		elementShapeList.add(requestReplyShape);
		previousElementModelShape = currentElementModelShape;
		currentElementModelShape = requestReplyShape;

		SequenceFlow seqRequestReplyObj = new SequenceFlow();
		sequenceFlow++;
		addSeqAttribute(seqRequestReplyObj, "ErrSequenceFlow_" + 4, previousElementNode, currentElementNode);
		sequenceFlowList.add(seqRequestReplyObj);

		LinkedList<Map<String, Double>> coordinateList1 = new LinkedList();
		// sequence flow source start error coordinate
		xOffset = xOffset + startEventShape.getWidth() / 2;
		Map<String, Double> coordinateS1 = new HashMap();
		coordinateS1.put("x", xOffset);
		coordinateS1.put("y", yOffset);
		coordinateList1.add(coordinateS1);
		// sequence flow target groovy coordinate
		xOffset = xOffset + 100.0 + callActivityShape.getWidth() / 2;
		Map<String, Double> coordinateT1 = new HashMap();
		coordinateT1.put("x", xOffset);
		coordinateT1.put("y", yOffset);
		coordinateList1.add(coordinateT1);

		SequenceFlowShape seqFlowShape2 = new SequenceFlowShape();
		addSeqShapeAttri(previousElementModelShape, currentElementModelShape, seqRequestReplyObj, coordinateList1,
				seqFlowShape2);
		sequenceShapeList.add(seqFlowShape2);

		currentElementModelShape.setY(yOffset - callActivityShape.getHeight() / 2);
		currentElementModelShape.setX(xOffset - callActivityShape.getWidth() / 2);

		// xOffset=this.x;
		// yOffset=this.y;
		previousElementNode = currentElementNode;
		previousElementModelShape = currentElementModelShape;

		// end event

		ElementModel endEventObj = new ElementModel();
		addEleAttribute(endEventObj, "ErrEndEvent", "Error End 1", null,
				appGenUtility.getExtensionElementKeyValue(AppGenConstant.END_EVENT));
		partiList.add(endEventObj);

		ElementModelShape endEventShape = new ElementModelShape();
		addEleShapeAttri(endEventObj, endEventShape, 32.0, 32.0);
		elementShapeList.add(endEventShape);

		SequenceFlow seqEndObj = new SequenceFlow();
		addSeqAttribute(seqEndObj, "ErrSequenceFlow_" + 2, contenModifier, endEventObj);
		sequenceFlowList.add(seqEndObj);

		LinkedList<Map<String, Double>> coordinate_List = new LinkedList<>();
		// sequence flow source coordinate
		xOffset = xOffset + callActivityShape.getWidth() / 2;
		Map<String, Double> coordinate_S = new HashMap<>();
		coordinate_S.put("x", xOffset);
		coordinate_S.put("y", yOffset);
		coordinate_List.add(coordinate_S);
		// sequence flow target coordinate
		xOffset = xOffset + 100.0 + endEventShape.getWidth() / 2;
		Map<String, Double> coordinate_T = new HashMap<>();
		coordinate_T.put("x", xOffset);
		coordinate_T.put("y", yOffset);
		coordinate_List.add(coordinate_T);
		//
		subProcessShape.setWidth(440.0);// xOffset - 150.0

		SequenceFlowShape seqEndShape = new SequenceFlowShape();
		addSeqShapeAttri(requestReplyShape, endEventShape, seqEndObj, coordinate_List, seqEndShape);
		sequenceShapeList.add(seqEndShape);
		//
		endEventShape.setX(xOffset - endEventShape.getWidth() / 2);
		endEventShape.setY(yOffset - endEventShape.getHeight() / 2);

		if (xOffset > this.bpmnDiagram.getParticipantProcessWidth()) {// xOffset+400>this.bpmnDiagram.getParticipantProcessWidth()
			this.bpmnDiagram.setParticipantProcessWidth(xOffset);// xOffset+400 //(/2
			// 300)
		}
		if (yOffset > this.bpmnDiagram.getParticipantProcessHeight())
			this.bpmnDiagram.setParticipantProcessHeight(yOffset + 80.0);

	}



	private void poBatchProcessingTemplate1(Map.Entry<Integer, IcoSenderMapping> icosender, Map<Integer, List<ChannelMapModel>> channelListMap, Map<Integer, Map<String, String>> omIcoLinkMap, PoTenant poTenant, Map<Integer, List<OperationMapping>> omMap, ObjectTypesLinks objType, long projectId, List<AssesmentModel> assesList, Map<Integer, String> vmMap) throws Exception {
		List<ChannelMapModel> channelList = channelListMap.get(icosender.getKey());
		Map<String, String> omNmAndNmspcMap = omIcoLinkMap.get(icosender.getKey());
		logger.info("LindePoToCpiMigrationServiceImpl poBatchProcessing() for ico " + icosender.getKey() + " Started");
		// creating folder structure
		// File sourceDirectory = new File(folderStructure);
		File destinationDirectory = new File(AppGenUtility.getFilePathIflow(
				icosender.getValue().getProjectName(), icosender.getValue().getProjId(),
				icosender.getValue().getIcoid(), poTenant.getPoTenantId()));
		// AppGenUtility.copyDirectory(sourceDirectory, destinationDirectory);

		InputStream zipfolderLocation = getClass().getClassLoader()
				.getResourceAsStream("IflowFolderStructure.zip");
		AppGenUtility.UnZipFile(zipfolderLocation, destinationDirectory.getPath());

        // operation mapping process
        Object[] objarr = operMappingServiceImpl.process(omNmAndNmspcMap, icosender.getValue(),
                poTenant, objType, "no");
        String projectName = icosender.getValue().getProjectName();

        File folder = new File(AppGenUtility.getFilePathIflow(icosender.getValue().getProjectName(), icosender.getValue().getProjId(), icosender.getValue().getIcoid(), poTenant.getPoTenantId()) + "\\src\\main\\resources\\mapping");

        List<OperationMapping> operationmappingList = (List<OperationMapping>) objarr[0];
        omMap.put(icosender.getKey(), operationmappingList);

        boolean isAsync = true;
        IcoReceiverInterface receiver = icosender.getValue().getIcoRecevList().get(0);
        List<MessageMapping> messageMappingList = new LinkedList<>();
        for (OperationMapping operationMap : operationmappingList) {// match swid too
            if (null != receiver.getOpMappingName()
                    && receiver.getOpMappingName().equalsIgnoreCase(operationMap.getOperationMappingName())
					&& receiver.getOpMappingNamespace().equalsIgnoreCase(operationMap.getOperationMappingNmspc())) {
				messageMappingList = operationMap.getMappingList().stream()
						.map(Mapping::getMessageMapping)
						.filter(msg -> msg != null)
						.collect(Collectors.toList());
			}
		}
		for (MessageMapping messageMap : messageMappingList) {
			if (messageMap.isSync()) {
				isAsync = false;
			}
		}
        if (isAsync) {

            ChannelMapModel receiverChannelObj = null;
            for (ChannelMapModel channel : channelList) {
                if (receiver.getReceiverChannelId().equalsIgnoreCase(channel.getChannelId())
                        && receiver.getReceiverId().equalsIgnoreCase(channel.getPartyId())
                        && receiver.getReceiverCompId().equalsIgnoreCase(channel.getComponentId())) {
                    receiverChannelObj = channel;
                    break;
                }
            }

            ChannelMapModel senderChannelObj = null;
            for (ChannelMapModel channel : channelList) {
                if (icosender.getValue().getSenderChannelId().equalsIgnoreCase(channel.getChannelId())
                        && icosender.getValue().getSenderId().equalsIgnoreCase(channel.getPartyId())
                        && icosender.getValue().getSenderCompId().equalsIgnoreCase(channel.getComponentId())) {
                    senderChannelObj = channel;

                    break;
                }
            }

            //Recevier is salesForce
            if (receiverChannelObj.getName().equals("SFDC")) {


                boolean isJDBCSen = senderChannelObj.getName().equals("JDBC");

                if (folder.exists() && folder.isDirectory()) {
                    File[] files = folder.listFiles((dir, name) -> name.toLowerCase().endsWith(".mmap"));

                    if (files != null && files.length > 0) {
                        for (File file : files) {
                            // sender to be recognized as jdbc or not
                            transformLindeMapping(file.getAbsoluteFile().toPath(), isJDBCSen);
                            System.out.println("Found: " + file.getAbsolutePath());
                        }
                    } else {
                        System.out.println("No .mmap file found in: " + folder.getPath());
                    }
                } else {
                    System.out.println("Invalid folder path!");
                }

                //step03
                createBpmnDiagramStep03(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(), projectId, icosender.getKey(), icosender.getValue(), channelList, operationmappingList);

            } else {
                createBpmnDiagramAsync(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(),
                        projectId, icosender.getKey(), icosender.getValue(), channelList, operationmappingList);
            }

			long c = icosender.getValue().getIcoid();

			if (!(receiverChannelObj.getName().matches("RFC|IDoc_AAE")
					|| receiverChannelObj.getMsgProtocol().equalsIgnoreCase("XI"))) {
				destinationDirectory = new File(AppGenUtility.getFilePathIflow(
						icosender.getValue().getProjectName(), icosender.getValue().getProjId(),
                        ++c, poTenant.getPoTenantId()));
                zipfolderLocation = getClass().getClassLoader()
                        .getResourceAsStream("IflowFolderStructure.zip");
                AppGenUtility.UnZipFile(zipfolderLocation, destinationDirectory.getPath());

                if (receiverChannelObj.getName().equals("SFDC")) {

                    //step05
                    createBpmnDiagramStep05(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(), projectId, (int) c, icosender.getValue(), channelList, operationmappingList);

                } else {
                    createBpmnDiagramAsyncAdapterConfig(projectName, poTenant.getPoTenantAlias(),
                            poTenant.getPoTenantId(), projectId, (int) c, icosender.getValue(),
                            channelList, operationmappingList);
                }
            }

			if (!(senderChannelObj.getName().matches("RFC|IDoc_AAE") || senderChannelObj.getMsgProtocol().equalsIgnoreCase("XI")) && icosender.getValue().isLindeSender()) {
				destinationDirectory = new File(AppGenUtility.getFilePathIflow(
						icosender.getValue().getProjectName(), icosender.getValue().getProjId(),
						++c, poTenant.getPoTenantId()));
				zipfolderLocation = getClass().getClassLoader()
						.getResourceAsStream("IflowFolderStructure.zip");
				AppGenUtility.UnZipFile(zipfolderLocation, destinationDirectory.getPath());
				createBpmnDiagramSender(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(), projectId,
						(int) c, icosender.getValue(), channelList, operationmappingList);

                destinationDirectory = new File(AppGenUtility.getFilePathIflow(
                        icosender.getValue().getProjectName(), icosender.getValue().getProjId(),
                        ++c, poTenant.getPoTenantId()));
                zipfolderLocation = getClass().getClassLoader()
                        .getResourceAsStream("IflowFolderStructure.zip");
                AppGenUtility.UnZipFile(zipfolderLocation, destinationDirectory.getPath());

                createBpmnDiagramRecDetermination(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(), projectId,
                        (int) c, icosender.getValue(), channelList, operationmappingList);

            }
        } else {
            createBpmnDiagramSync(projectName, poTenant.getPoTenantAlias(), poTenant.getPoTenantId(), projectId,
                    icosender.getKey(), icosender.getValue(), channelList, operationmappingList);
            uploadService.updatePipline(poTenant.getPoTenantId(), projectId, icosender.getKey());
        }

		Map<String, OperationMapping> operationmap = (Map<String, OperationMapping>) objarr[1];

		assessService.createAssesList(icosender.getValue(), channelList, operationmap, projectId,
				(long) poTenant.getPoTenantId(), assesList, null, poTenant, new HashSet<>(), new HashSet<>(),
				new HashSet<>(), new HashSet<>(), new HashSet<>(), new HashMap<>(), new HashSet<>(),new HashMap<>());
		// creating vm
		String vm = commonService.creatingVM(icosender.getValue(), poTenant);
		vmMap.put(icosender.getKey(), vm);
	}

	private void createBpmnDiagramRecDetermination(String projectName, String tenantAlias, long potenantId, Long projectId, int icoId,
			IcoSenderMapping icoSender, List<ChannelMapModel> channelList, List<OperationMapping> operationmappingList)throws Exception {
		String source = AppGenUtility.getFilePathIflow(projectName, projectId, icoId, potenantId);
		List<ElementModel> partiList = new ArrayList<>();
		List<MessageFlow> msgFlowList = new ArrayList<>();
		List<SequenceFlow> sequenceFlowList = new ArrayList<>();
		List<ElementModelShape> elementShapeList = new ArrayList();
		List<MessageFlowShape> msgShapeList = new ArrayList<>();
		List<SequenceFlowShape> sequenceShapeList = new ArrayList<>();
		List<Process> processList = new ArrayList<>();
		Integer participant = 0;
		Integer messageFlow = 0;
		Integer router = 0;
		Integer sequenceFlow = 0;
		Integer callActivity = 0;
		Integer endEvent = 0;
		Integer excGateway = 0;
		Integer pgpEnc = 0;
		ElementModel currentElementNode = null;
		ElementModel previousElementNode = null;
		ElementModel routerElementNode = null;
		this.bpmnDiagram.setParticipantProcessHeight(0.0);// set so next ico dont use it
		this.bpmnDiagram.setParticipantProcessWidth(0.0);
		this.bpmnDiagram.setMaxEndEventX(0.0);
		this.x = 0;
		this.y = 0;

		prepareDataForReceiverDetermination(icoSender, channelList, partiList, msgFlowList,
