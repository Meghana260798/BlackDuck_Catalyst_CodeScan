	public static class RoleData {
		private final String typeId;
		private final List<String> elements;

		public RoleData(String typeId, List<String> elements) {
			this.typeId = typeId;
			this.elements = elements;
		}

		public String getTypeId() {
			return typeId;
		}

		public List<String> getElements() {
			return elements;
		}

		@Override
		public String toString() {
			return "typeId=" + typeId + ", elements=" + elements;
		}
	}

	public static RoleData getRoleData(Document doc, String roleName) {
		NodeList lnkRoles = doc.getElementsByTagName("p1:lnkRole");
		for (int i = 0; i < lnkRoles.getLength(); i++) {
			Element lnkRole = (Element) lnkRoles.item(i);
			String roleAttr = lnkRole.getAttribute("role");
			if (roleName.equals(roleAttr)) {
				// Found role
				Element keyElement = (Element) lnkRole.getElementsByTagName("p1:key").item(0);
				String typeId = keyElement.getAttribute("typeID");

				NodeList elemNodes = keyElement.getElementsByTagName("p1:elem");
				List<String> elems = new ArrayList<>();
				for (int j = 0; j < elemNodes.getLength(); j++) {
					elems.add(elemNodes.item(j).getTextContent().trim());
				}

				return new RoleData(typeId, elems);
			}
		}
		return null; // not found
	}

	public void  poCpiMigartion(List<UploadPoIco> uploadIcos, Long projectId, Long poTenantId, Long cpiTenantId, ObjectTypesLinks objType)
			throws Exception {
		logger.info("LindePoToCpiMigrationServiceImpl poCpiMigartion() :: Started");
		Tenants cpiTenant = tenantService.getTenantById((int) (long) cpiTenantId);
		List<UploadPoIcoModel> uploadIcoModelList = new LinkedList<UploadPoIcoModel>();
		Map<Integer, IcoSenderMapping> icoSenderMap = new HashMap<Integer, IcoSenderMapping>();
		Map<Integer, Map<String, String>> omIcoLinkMap = new HashMap<Integer, Map<String, String>>();
		int counter = 20;
		Map<String, Integer> keymapforReceiver = new HashMap<>();
		Set<Integer> senderSet = new HashSet<>();

		try {
			PoTenant poTenant = poTenantService.getPoTenantById((int) (long) poTenantId);
			Project project = projectService.getProject((int) (long) projectId);

			// flat to heiarchical structure
			IcoSenderMapping icosender = null;

			for (UploadPoIco ico : uploadIcos) {
				int id=ico.getIcoId();
				String recKey=id+ico.getReceiverPartyId()+ico.getReceiverSystem()+ico.getReceiverInterface()+ico.getReceiverInterfaceNamespace();
				if (icoSenderMap.containsKey(keymapforReceiver.get(recKey))) {
					icosender = icoSenderMap.get(keymapforReceiver.get(recKey));
					ico.setIcoId(keymapforReceiver.get(recKey));
				}
				else {
					keymapforReceiver.put(recKey, counter);
					icosender = new IcoSenderMapping();
					icosender.setIcoid(counter);
					if(ico.getPipeline().equals("custom_pipeline_MultiReceiver")){
						icosender.setPipeline(AppGenConstant.Linde_Pipeline_1);
						ico.setPipeline(AppGenConstant.Linde_Pipeline_1);
					} else if (ico.getPipeline().equalsIgnoreCase("custom_pipeline_SingleReceiverSalesforce")) {
						icosender.setPipeline(AppGenConstant.Linde_Pipeline_2);
						ico.setPipeline(AppGenConstant.Linde_Pipeline_2);
					}
					icosender.setInterfaceName(ico.getSenderInterface());
					icosender.setInterfaceNamespace(ico.getSenderInterfaceNamespace());
					icosender.setSenderCompId(ico.getSenderSystem());
					icosender.setSenderChannelId(ico.getSenderAdapterName());
					// continue add flag for PI
					icosender.setSenderId(ico.getSenderPartyId());
					icosender.setProjId(projectId);
					icosender.setProjectName(project.getProjectName());
					icosender.setCpiName(ico.getCpiPackageName());
					icosender.setCpiPackageId(ico.getCpiPackageId());
					icosender.setCpiIflowName(ico.getCpiIflowName());
					icosender.setCpiIflowId(ico.getCpiIflowId());
					icosender.setVirtualHost(ico.getSenderHost());
					icosender.setVirtualPort(ico.getSenderPort());
					icosender.setSystemHoston(ico.getSenderSysHostOn());
					icosender.setLocationId(ico.getLocationId());
					icosender.setErrorHandlingTemplet(ico.getErrorHandlingTemplet());
				    icosender.setJmsReceiverIflId(ico.getJmsReceiverIflId());
					icosender.setJmsReceiverIflName(ico.getJmsReceiverIflName());
					icosender.setSenProcessDirect(ico.getSenProcessDirect());
					icosender.setReceiverDeterMapping("");
					icoSenderMap.put(counter, icosender);
					ico.setIcoId(counter);
					counter++;


                    if ((ico.getPipeline().equalsIgnoreCase(AppGenConstant.Linde_Pipeline_2)) && (ico.getSenderAdapterType().matches("RFC|IDoc_AAE") || ico.getSenderMessageProtocol().equalsIgnoreCase("XI"))) {

                        ico.setPipeline(ico.getPipeline() + "Sender_Step01");

                    } else {

                        if (!(ico.getReceiverAdapterType().matches("RFC|IDoc_AAE") || ico.getReceiverMessageProtocol().equalsIgnoreCase("XI"))) {
                            ico.setPipeline(ico.getPipeline() + "Adapter");
                            counter++;
                        }

                        if (!(ico.getSenderAdapterType().matches("RFC|IDoc_AAE") || ico.getSenderMessageProtocol().equalsIgnoreCase("XI")) && !senderSet.contains(id)) {
                            counter += 2;
                            ico.setPipeline(ico.getPipeline() + "Sender");
                            senderSet.add(id);
                            icosender.setLindeSender(true);
                        }
                    }

				}
				setIcoReceiver(omIcoLinkMap, ico, icosender);
				// }
				UploadPoIcoModel uploadIcoModel = new UploadPoIcoModel();
				BeanUtils.copyProperties(ico, uploadIcoModel);
				uploadIcoModel.setProjectId(projectId);
				uploadIcoModel.setPoTenantId(poTenantId);
				uploadIcoModel.setErrorHandlingTemplet(ico.getErrorHandlingTemplet());
				uploadIcoModelList.add(uploadIcoModel);

			}
			// saving in db
			uploadService.savePoIcoList(uploadIcoModelList);

			// batching
			int batch_size = batch_preview_size;
			Map<Integer, IcoSenderMapping> icosBatch = null;
			int batch_counter = 1;
			int mapSize = icoSenderMap.size();
			int totalSize = 0;
			for (Map.Entry<Integer, IcoSenderMapping> entry : icoSenderMap.entrySet()) {
				totalSize++;
				if (batch_counter == 1) {
					icosBatch = new HashMap<Integer, IcoSenderMapping>();
					icosBatch.put(entry.getKey(), entry.getValue());
				} else {

					icosBatch.put(entry.getKey(), entry.getValue());
				}

				if (batch_counter == batch_size || mapSize == totalSize) {
					try {
						batch_counter = 0;
						// batch processing
							poBatchProcessing(icosBatch, omIcoLinkMap, poTenant, projectId, objType, cpiTenant);// pass pomodel

					} catch (Exception e) {
						// userdefined exception
						e.printStackTrace();
					}
				}

				batch_counter++;

			}


		} catch (Exception e) {
			// TODO Auto-generated catch block
			logger.error("LindePoToCpiMigrationServiceImpl poCpiMigartion() :: ", e);
			throw e;
		}
		logger.info("LindePoToCpiMigrationServiceImpl poCpiMigartion() :: End");
	}

	private void setIcoReceiver(Map<Integer, Map<String, String>> omIcoLinkMap, UploadPoIco ico,
			IcoSenderMapping icosender) {
		IcoReceiverInterface receiver = new IcoReceiverInterface();
		receiver.setReceiverId(ico.getReceiverPartyId());
		receiver.setReceiverInterface(ico.getReceiverInterface());
		receiver.setReceiverNamespace(ico.getReceiverInterfaceNamespace());
		receiver.setReceiverCompId(ico.getReceiverSystem());
		receiver.setReceiverChannelId(ico.getReceiverAdapterName());
		receiver.setOpMappingName(ico.getMappingName());
		receiver.setOpMappingNamespace(ico.getMappingNamespace());
		receiver.setSwftVerId(ico.getSwftVerID());
		receiver.setIcoRecId(ico.getReceiverId());
		receiver.setVirtualPort(ico.getReceiverPort());
		receiver.setVirtualHost(ico.getReceiverHost());
		receiver.setSystemHoston(ico.getReceiverSysHostOn());
		receiver.setLocationId(ico.getLocationId());
		receiver.setSecurityPasswd(ico.getSecurityPassword());
		receiver.setCondition(ico.getRecCondition());
		receiver.setInterfaceCondition(ico.getInterfaceCondition());
		receiver.setMaintainOrderAtRuntime(ico.getMaintainOrdRunTime());
		if (null != ico.getRecMappingParameter() && !ico.getRecMappingParameter().equals("")) {
			List<MappingParameter> mpList = new ArrayList<>();
			String[] arrOfStr = ico.getRecMappingParameter().split("\\|\\|");
			for (int i = 0; i < arrOfStr.length; i++) {
				String mpString = arrOfStr[i];
				MappingParameter mp = new MappingParameter();
				mp.setType(mpString.split(":")[0]);
				mp.setName(mpString.split(":")[1]);
				mp.setValue(mpString.split(":")[2]);
				mpList.add(mp);
			}

			receiver.setMappingParameter(mpList);
		}

		List<IcoReceiverInterface> recList = icosender.getIcoRecevList();

		if(recList==null) {
			 recList = new ArrayList<>();
			icosender.setIcoRecevList(recList);
		}
		recList.add(receiver);


		Map<String, String> OmNmspc = omIcoLinkMap.get(ico.getIcoId());
		if(OmNmspc==null) {
			OmNmspc = new HashMap<String, String>();
			omIcoLinkMap.put(ico.getIcoId(), OmNmspc);
		}
		if(StringUtils.isNotBlank(ico.getMappingName()))
			   OmNmspc.put(ico.getMappingName() + " | " + ico.getMappingNamespace(), ico.getSwftVerID());

	}

	// batch processing
	private void poBatchProcessing(Map<Integer, IcoSenderMapping> icosBatch,
			Map<Integer, Map<String, String>> omIcoLinkMap, PoTenant poTenant, long projectId, ObjectTypesLinks objType, Tenants cpiTenant)
			throws Exception {
		logger.info("LindePoToCpiMigrationServiceImpl poBatchProcessing() :: Started");

		Map<Integer, List<OperationMapping>> omMap = new LinkedHashMap<>();
		List<PoIcoBatchExceptionModel> poIcoEx = new ArrayList<>();
		List<AssesmentModel> assesList = new ArrayList<>();
		  Map<Integer,String> vmMap=  new LinkedHashMap<>();
		try {
			// pass ico batch to get channel details
			Map<Integer, List<ChannelMapModel>> channelListMap = commonService.getChannelInfo(icosBatch, poTenant.getPoTenantId(),
					AppGenConstant.PREVIEW);

			for (Map.Entry<Integer, IcoSenderMapping> icosender : icosBatch.entrySet()) {
				try {
					if (icosender.getValue().getPipeline().equalsIgnoreCase(AppGenConstant.Linde_Pipeline_1))
						poBatchProcessingTemplate1(icosender,channelListMap,omIcoLinkMap,poTenant,omMap,objType,projectId,assesList,vmMap);
					else if (icosender.getValue().getPipeline().equalsIgnoreCase(AppGenConstant.Linde_Pipeline_2))
                        poBatchProcessingTemplate2(icosender, channelListMap, omIcoLinkMap, poTenant, omMap, objType, projectId, assesList, vmMap);
				} catch (Exception e) {
					e.printStackTrace();
					logger.error("LindePoToCpiMigrationServiceImpl :::: poBatchProcessing() :: ", e);
					channelListMap.remove(icosender.getKey());
					omMap.remove(icosender.getKey());
					PoIcoBatchExceptionModel poIco = new PoIcoBatchExceptionModel();
					poIco.setIcoId(icosender.getKey());
					poIco.setErrorMsg(e.getMessage());
					poIcoEx.add(poIco);
				}

				logger.info("LindePoToCpiMigrationServiceImpl poBatchProcessing() for ico " + icosender.getKey() + " ended");
			}

			// updating error if exists
			if (!poIcoEx.isEmpty()) {
				uploadService.updateExceptionList(poTenant.getPoTenantId(), projectId, poIcoEx);
			}

			Map<Long, Map<String, String>> complexity = new HashMap<>();
			Set<String> redesignSet = new HashSet<>();
			Set<String> regenerateSet = new HashSet<>();
			Set<String> remediateSet = new HashSet<>();

			Map<String, String> remMap = new HashMap<>();
			Map<String, String> redMap = new HashMap<>();

			Map<Long, String> redesignMap = new HashMap<>();
			Map<Long, String> remediateMap = new HashMap<>();



			assessService.assessComplexity(assesList, complexity, redesignSet, regenerateSet, remediateSet, remMap,
					redMap, redesignMap, remediateMap,new HashMap<>(),new HashMap<>(),new HashMap<>(), new HashSet<>(), new HashMap<>());
			// updating for complexity
			// if(!channelListMap.isEmpty())
			// mergeComplexity(channelListMap, omMap, poTenant.getPoTenantId(), projectId);

			uploadService.updatePoIcoAssessList(assesList, poTenant.getPoTenantId(), projectId,vmMap);

		} catch (Exception e) {
			e.printStackTrace();
			logger.error("LindePoToCpiMigrationServiceImpl :::: poBatchProcessing() :: ", e);
			for (Map.Entry<Integer, IcoSenderMapping> entry : icosBatch.entrySet()) {
				PoIcoBatchExceptionModel poIco = new PoIcoBatchExceptionModel();
				poIco.setIcoId(entry.getKey());
				poIco.setErrorMsg(e.getMessage());
				poIcoEx.add(poIco);
			}
			uploadService.updateExceptionList(poTenant.getPoTenantId(), projectId, poIcoEx);
		}
		logger.info("LindePoToCpiMigrationServiceImpl poBatchProcessing() :: ended");
	}

