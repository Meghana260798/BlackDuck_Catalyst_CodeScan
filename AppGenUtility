	private static byte[] getOutputByte(BodyPart bodyPart) {
		byte[] targetArray = null;
		try {
			targetArray = new byte[bodyPart.getInputStream().available()];
			bodyPart.getInputStream().read(targetArray);
			if (bodyPart.getInputStream() != null) {
				bodyPart.getInputStream().close();
			}

		} catch (Exception e) {
			logger.error("AppGenUtility :::: getOutputByte :: ", e);
			e.printStackTrace();
		}
