	// to extract json from get batch call
	public static void parseMutipart(String parseString, List<JSONObject> resJson) {
		try {
			ByteArrayDataSource datasource = new ByteArrayDataSource(parseString, "multipart/mixed");
			MimeMultipart multipart = new MimeMultipart(datasource);
			int count = multipart.getCount();
			// System.out.println("count " + count);
			for (int i = 0; i < count; i++) {
				BodyPart bodyPart = multipart.getBodyPart(i);
				if (bodyPart.isMimeType("application/json")) {
					byte[] arrOfByte;
					arrOfByte = getOutputByte(bodyPart);

					String Json = new String(arrOfByte);
					JSONObject obj = new JSONObject(Json);
					resJson.add(obj);
				} else {
					// if any other data then here
					// System.out.println("default " +
					// bodyPart.getContentType());
					// System.out.println(bodyPart.getContent().toString());
					byte[] arrOfByte = getOutputByte(bodyPart);

					String jsonMultipart = new String(arrOfByte);
					jsonMultipart = "--batch_1\r\n" + jsonMultipart;

					parseMutipart(jsonMultipart, resJson);
				}

			}
		} catch (Exception e) {
			logger.error("AppGenUtility :::: parseMutipart :: ", e);
			e.printStackTrace();
		}
	}

