	public void createPropDefinationMap(String component, String direction, String participantId) {

		String adapterKey1 = component + direction;
		Map<String, Parameter> adpaterYaml = this.readYaml.getAdapterkey();
		Map<String, Parameter> adpaterAdd = new HashMap<String, Parameter>();
		
		List<Map<String, Parameter>> adapterList = new ArrayList<Map<String, Parameter>>();
		adapterList.addAll(this.bpmnDiagram.getAdapterList());
		String concatName = direction + participantId + "_";

		for (Map.Entry<String, Parameter> adapter : adpaterYaml.entrySet()) {
			 Parameter p = new Parameter();
			if (adapterKey1.equalsIgnoreCase(adapter.getKey())) {
				 Map<String, Attributes> attMap = new  HashMap<String, Attributes>();
				for (Map.Entry<String, Attributes> att : adapter.getValue().getParameter().entrySet()) {
					Attributes attCpy = new Attributes();
					String key = att.getValue().getName();
					String value =concatName + key;
					BeanUtils.copyProperties(att.getValue(), attCpy);
					attCpy.setName(value);
					attMap.put(att.getKey(), attCpy);
				}
				p.setParameter(attMap);
				adpaterAdd.put(adapter.getKey(),p);
				adapterList.add(adpaterAdd);

			}
			this.bpmnDiagram.setAdapterList(adapterList);
		}
	}

