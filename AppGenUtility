					value = "<row><cell id='SignerUserID'>"+parameters.getOrDefault("ownPrivateKey","")+"</cell></row>";
				} else if(key.equalsIgnoreCase("PgpEncryptionUserIDs")) {
					value = "<row><cell id='EncryptUserID'>"+parameters.getOrDefault("partnerPublicKey","")+"</cell></row>";
				} else if (key.equalsIgnoreCase("Key_Length")) {
