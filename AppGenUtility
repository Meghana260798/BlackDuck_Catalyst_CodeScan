	public static HttpHeaders getCsrfToken(String tntURL, String authorisation) {
		HttpHeaders headers = new HttpHeaders();
		// String base64Creds = new String(Base64.encodeBase64((userName + ":" +
		// password).getBytes()));

		headers.add("Authorization", "Basic " + authorisation);
		headers.add("x-csrf-token", "Fetch");
		HttpEntity<String> request = new HttpEntity<>(headers);

		return new RestTemplate()
				.exchange(tntURL.concat(AppGenConstant.CSRF_TOKEN_FETCH_API), HttpMethod.GET, request, String.class)
				.getHeaders();
	}

	public static HttpEntity<String> setHeaders(String csrfToken, String cookie, String authorisation,
			String requestJson) {
		HttpHeaders headers = new HttpHeaders();
		// String base64Creds = new String(Base64.encodeBase64((userName + ":" +
		// password).getBytes()));

		headers.add("Authorization", "Basic " + authorisation);

		if (csrfToken != null)
			headers.add("x-csrf-token", csrfToken);

		if (cookie != null)
			headers.add("cookie", cookie);
		headers.add("Content-Type", "application/json");

		return new HttpEntity<>(requestJson, headers);
	}

	public static byte[] writeExcelFile(List<IFlow> iflowList) throws Exception {
		ByteArrayOutputStream bos = null;
		Workbook workbook = null;

		try {
			InputStream stream = ClassLoader
					.getSystemResourceAsStream("templates/".concat(AppGenConstant.IFLOW_FILE_NAME));
			workbook = new XSSFWorkbook(stream);
			Sheet sheet = workbook.getSheetAt(0);

			int rowIndex = 1;

			if (!CollectionUtils.isEmpty(iflowList)) {
				for (IFlow iflowObj : iflowList) {
					Row row = sheet.createRow(rowIndex);
					row.createCell(0).setCellValue(Objects.isNull(iflowObj.getId()) ? "" : iflowObj.getId());

					row.createCell(1).setCellValue(Objects.isNull(iflowObj.getVersion()) ? "" : iflowObj.getVersion());

					rowIndex++;
				}
			}

			bos = new ByteArrayOutputStream();
			workbook.write(bos);

			return bos.toByteArray();
		} catch (IOException e) {
			throw new IOException();
		} catch (Exception e) {
			throw new Exception();
		} finally {
			if (bos != null)
				bos.close();

			if (workbook != null)
				workbook.close();
		}
	}


	public static MediaType getMediaTypeForFileName(ServletContext servletContext, String fileName) {
		String mineType = servletContext.getMimeType(fileName);
		try {
			MediaType mediaType = MediaType.parseMediaType(mineType);
			return mediaType;
		} catch (Exception e) {
			return MediaType.APPLICATION_OCTET_STREAM;
		}
	}

