	public static Document decryptFile(String encryptedInputFileName) throws IOException, PGPException, ParserConfigurationException, SAXException {
        Document document = null;
        InputStream in = null;
        InputStream keyIn = null;
        PGPPrivateKey sKey = null;
        PGPPublicKeyEncryptedData pbe = null;
        PGPSecretKeyRingCollection pgpSec = null;
        
        try {
            // Input stream for encrypted file
            in = new BufferedInputStream(new ByteArrayInputStream(encryptedInputFileName.getBytes(StandardCharsets.UTF_8)));
            keyIn = new BufferedInputStream(new FileInputStream(secretKeyPath));

            in = PGPUtil.getDecoderStream(in);

            // Initialize PGP object factory to parse the encrypted data
            JcaPGPObjectFactory pgpF = new JcaPGPObjectFactory(in);
            PGPEncryptedDataList enc;
            Object o = pgpF.nextObject();

            // Handle encrypted data objects
            if (o instanceof PGPEncryptedDataList) {
                enc = (PGPEncryptedDataList) o;
            } else {
                enc = (PGPEncryptedDataList) pgpF.nextObject();
            }

            Iterator<?> it = enc.getEncryptedDataObjects();
            pgpSec = new PGPSecretKeyRingCollection(PGPUtil.getDecoderStream(keyIn), new JcaKeyFingerprintCalculator());

            // Find the private key that matches the encrypted key
            while (sKey == null && it.hasNext()) {
                pbe = (PGPPublicKeyEncryptedData) it.next();
                PGPSecretKey pgpSecKey = pgpSec.getSecretKey(pbe.getKeyID());

                if (pgpSecKey != null) {
                    sKey = pgpSecKey.extractPrivateKey(new JcePBESecretKeyDecryptorBuilder().setProvider("BC").build(passphrase));
                }
            }

            // Decrypt the data stream
            InputStream clear = pbe.getDataStream(new JcePublicKeyDataDecryptorFactoryBuilder().setProvider("BC").build(sKey));
            JcaPGPObjectFactory plainFact = new JcaPGPObjectFactory(clear);
            Object message = plainFact.nextObject();

            // Handle compressed data
            if (message instanceof PGPCompressedData) {
                PGPCompressedData cData = (PGPCompressedData) message;
                JcaPGPObjectFactory pgpFact = new JcaPGPObjectFactory(cData.getDataStream());
                message = pgpFact.nextObject();
            }

            // Extract the literal data
            if (message instanceof PGPLiteralData) {
                PGPLiteralData ld = (PGPLiteralData) message;
                InputStream unc = ld.getInputStream();

                // Unzip the data and read it as a string
                String fileContent = unzipToString(unc);
                System.out.println(fileContent);
                document = (Document) Jsoup.parse(fileContent);
                System.out.println("Unzipped Content: ");
            }

            // Verify integrity
            if (pbe.isIntegrityProtected() && pbe.verify()) {
                System.out.println("Integrity Verified");
            } else {
                System.out.println("Integrity Not Verified");
            }
        } finally {
            // Close all streams to avoid memory leaks
            if (in != null) {
                in.close();
            }
            if (keyIn != null) {
                keyIn.close();
            }
            
        }

        return document;
    }
         
	     
