	     // Helper method to unzip and return the content as a string
	     private static String unzipToString(InputStream zipStream) throws IOException {
	         StringBuilder stringBuilder = new StringBuilder();
	         ZipInputStream zis = new ZipInputStream(zipStream);
	         ZipEntry entry;

	         // Read the zip entry content
	         while ((entry = zis.getNextEntry()) != null) {
	             // Read the content of each file inside the zip entry
	             BufferedReader reader = new BufferedReader(new InputStreamReader(zis, StandardCharsets.UTF_8));
	             String line;
	             while ((line = reader.readLine()) != null) {
	                 stringBuilder.append(line).append("\n");
	             }
	             zis.closeEntry();
	         }
	         zis.close();
	         return stringBuilder.toString();
	     }
	     
